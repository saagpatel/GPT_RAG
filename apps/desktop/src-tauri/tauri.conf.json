{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPT_RAG Desktop",
  "version": "0.1.0",
  "identifier": "local.personal.gpt-rag",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GPT_RAG Desktop",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": [
      "binaries/gpt-rag-api",
      "binaries/gpt-rag-worker"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
